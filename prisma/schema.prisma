// prisma/schema.prisma
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Album {
  id          String      @id @default(uuid())
  title       String
  clientName  String
  shareToken  String      @unique
  password    String?     // optional bcrypt hash
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  ceremonies  Ceremony[]
}

model Ceremony {
  id        String   @id @default(uuid())
  name      String   // "Mehndi", "Sangeet", "Wedding", "Reception"
  albumId   String
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  photos    Photo[]
}

model Photo {
  id           String    @id @default(uuid())
  filename     String
  originalName String
  size         Int
  mimeType     String
  storageKey   String    // R2/S3 object key
  width        Int?
  height       Int?
  ceremonyId   String
  ceremony     Ceremony  @relation(fields: :ceremonyId, references: :id, onDelete: Cascade)
  comments     Comment[]
  createdAt    DateTime  @default(now())
}

model Comment {
  id        String   @id @default(uuid())
  body      String
  author    String   // "photographer" | "client" — no auth yet, honour-system
  photoId   String
  photo     Photo    @relation(fields: :photoId, references: :id, onDelete: Cascade)
  createdAt DateTime @default(now())
}
