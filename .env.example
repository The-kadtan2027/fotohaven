# Database (SQLite for local dev, swap for Postgres in prod)
# NOTE for Android/Termux: use an absolute path, e.g.:
#   DATABASE_URL="file:/data/data/com.termux/files/home/fotohaven/prisma/dev.db"
# The termux-setup.sh script sets this automatically.
DATABASE_URL="file:./dev.db"

# Cloudflare R2 (or any S3-compatible storage)
# Get these from: Cloudflare Dashboard â†’ R2 â†’ Manage R2 API Tokens
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key"
R2_SECRET_ACCESS_KEY="your_r2_secret_key"
R2_BUCKET_NAME="fotohaven"
R2_PUBLIC_URL="https://your-bucket.your-domain.com"  # R2 public domain or custom domain

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_SECRET="your-random-secret-for-tokens"  # openssl rand -hex 32
RESEND_API_KEY="re_4n55TcwB_8VsLWEFXWfefmW8BaDRBXchq"
# Guest OTP / Face Discovery
GUEST_OTP_FROM_EMAIL="FotoHaven <notifications@fotohaven.app>"
# Testing only: skip guest OTP email/validation when true
GUEST_OTP_BYPASS="false"

# Face discovery tuning
NEXT_PUBLIC_FACE_MATCH_THRESHOLD="0.40"
NEXT_PUBLIC_FACE_STRONG_MATCH_THRESHOLD="0.36"
NEXT_PUBLIC_FACE_POSSIBLE_MATCH_THRESHOLD="0.40"
NEXT_PUBLIC_FACE_ENROLLMENT_SAMPLES="5"
NEXT_PUBLIC_FACE_ENROLLMENT_MIN_SUCCESS="3"
NEXT_PUBLIC_FACE_DETECTION_MIN_CONFIDENCE="0.50"
NEXT_PUBLIC_FACE_MIN_BOX_SIZE="48"
NEXT_PUBLIC_FACE_MAX_RESULTS="60"
