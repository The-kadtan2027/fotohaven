# Database (SQLite for local dev, swap for Postgres in prod)
DATABASE_URL="file:./dev.db"

# Cloudflare R2 (or any S3-compatible storage)
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key"
R2_SECRET_ACCESS_KEY="your_r2_secret_key"
R2_BUCKET_NAME="fotohaven"
R2_PUBLIC_URL="https://your-bucket.your-domain.com"  # R2 public domain or custom domain

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_SECRET="your-random-secret-for-tokens"  # openssl rand -hex 32
